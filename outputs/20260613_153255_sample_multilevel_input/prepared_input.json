{
  "title": "Policy-as-Spec Architecture Control Platform",
  "subtitle": "Overview plus capability expansion diagrams",
  "template": "platform_value_chain",
  "lanes": [
    {
      "side": "left",
      "title": "Lifecycle",
      "items": [
        "Author",
        "Resolve",
        "Enforce",
        "Deploy",
        "Assure"
      ]
    },
    {
      "side": "right",
      "title": "Interfaces",
      "items": [
        "REST API",
        "GraphQL",
        "MCP Server"
      ]
    }
  ],
  "zones": [
    {
      "id": "authoring",
      "title": "Authorship Layer",
      "subtitle": "Architect-owned specs",
      "items": [
        "Enterprise Architects",
        "LOB Architects",
        "YAML / JSON Specs"
      ],
      "columns": 1,
      "expand": false
    },
    {
      "id": "control_plane",
      "title": "Architecture Control Plane",
      "subtitle": "Single source of truth",
      "items": [
        "Spec Repository",
        "REST API",
        "GraphQL",
        "MCP Server",
        "Spec Resolution"
      ],
      "columns": 1,
      "expand": true,
      "children": [
        {
          "title": "Spec Repository",
          "subtitle": "",
          "items": [
            "Versioning",
            "Hashing",
            "Promotion",
            "Rollback"
          ]
        },
        {
          "title": "Interfaces",
          "subtitle": "",
          "items": [
            "GET /specs/resolve",
            "Dashboard queries",
            "MCP tools"
          ]
        }
      ]
    },
    {
      "id": "assurance",
      "title": "Architecture Assurance Fabric",
      "subtitle": "Pipeline enforcement",
      "items": [
        "arch-ctl CLI",
        "Build Stage",
        "Deploy Stage",
        "OPA Checks",
        "Topology Verification"
      ],
      "columns": 1,
      "expand": true,
      "children": [
        {
          "title": "Build Stage",
          "subtitle": "",
          "items": [
            "Dependency Scan",
            "IaC Plan",
            "Container Image Check"
          ]
        },
        {
          "title": "Deploy Stage",
          "subtitle": "",
          "items": [
            "BCP / DR Gates",
            "LB Spec",
            "Topology Verification"
          ]
        }
      ]
    },
    {
      "id": "targets",
      "title": "Multi-Cloud Targets",
      "subtitle": "Deployment endpoints",
      "items": [
        "AWS EKS",
        "AKS",
        "GCP",
        "Harness Delegates"
      ],
      "columns": 1,
      "expand": true,
      "children": [
        {
          "title": "AWS EKS",
          "subtitle": "",
          "items": [
            "Primary Cluster",
            "Delegate",
            "Policy Results"
          ]
        },
        {
          "title": "AKS / GCP",
          "subtitle": "",
          "items": [
            "Secondary Cluster",
            "Optional Cluster",
            "Delegate Routing"
          ]
        }
      ]
    },
    {
      "id": "controls",
      "title": "Cross-Cutting Components",
      "subtitle": "Governance and evidence",
      "items": [
        "Evidence Ledger",
        "Drift Detector",
        "Waiver Governance"
      ],
      "columns": 1,
      "expand": true,
      "children": [
        {
          "title": "Evidence & Drift",
          "subtitle": "",
          "items": [
            "Immutable Log",
            "Expiry Signals",
            "CVE Alerts"
          ]
        },
        {
          "title": "Waivers",
          "subtitle": "",
          "items": [
            "PR-based Workflow",
            "Expiry Limit",
            "Approval History"
          ]
        }
      ]
    }
  ],
  "flows": [
    {
      "from": "authoring",
      "to": "control_plane",
      "label": "publish specs"
    },
    {
      "from": "control_plane",
      "to": "assurance",
      "label": "resolved controls"
    },
    {
      "from": "assurance",
      "to": "targets",
      "label": "policy enforcement"
    },
    {
      "from": "targets",
      "to": "controls",
      "label": "evidence and drift"
    }
  ],
  "operations": [
    "Audit Trail",
    "Governance",
    "Security Controls"
  ],
  "footer": "Generate overview and Level 2 expansion diagrams where useful",
  "decomposition": {
    "auto_expand": true,
    "max_overview_zones": 6,
    "max_items_per_zone_overview": 5,
    "create_capability_children": true
  },
  "rendering_preferences": {
    "backend": "drawio-skill",
    "format": "png",
    "embed_xml": true
  }
}