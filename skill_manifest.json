{
  "name": "solution-architecture-diagram-skill",
  "version": "0.9.0",
  "author": "Arvind Radhakrishnen",
  "description": "Generate PNG and editable Draw.io architecture diagrams with per-run layout/palette recommendations, text wrapping, spelling guardrails, technology placement validation, and multi-level decomposition.",
  "entrypoints": {
    "instructions": "SKILL.md",
    "readme": "README.md",
    "usage": "docs/USAGE.md",
    "input_template": "examples/input_template.json",
    "normalize": "python prepare_architecture_input.py --input examples/my_architecture.json --output outputs/prepared_input.json",
    "build_prompt": "python build_drawio_prompt.py --input outputs/prepared_input.json --output outputs/drawio_prompt.md",
    "evaluate_png": "python evaluate_architecture_png.py --png outputs/solution_architecture.png --expected-json outputs/prepared_input.json --report outputs/diagram_eval_report.json",
    "plan_multilevel": "python plan_multilevel_architecture.py --input outputs/prepared_input.json --output outputs/multilevel_plan.json",
    "runner": "python run_architecture_skill.py --text \"Build a solution architecture diagram for ...\" --allow-parallel",
    "sub_agent_doc": "docs/sub_agent_orchestration.md",
    "renderer_adapter": "python render_with_drawio_adapter.py --run-dir outputs/<run_name> --config examples/renderer_config.json --dry-run",
    "runner_with_render": "python run_architecture_skill.py --json-input examples/sample_multilevel_input.json --allow-parallel --render --renderer-config examples/renderer_config.json",
    "layout_semantics": "docs/layout_semantics.md",
    "recommend_layouts": "python recommend_layouts.py --input outputs/prepared_input.json --output outputs/layout_recommendations.json --topn 2",
    "validate_technology_placement": "python validate_technology_placement.py --input outputs/prepared_input.json --output outputs/technology_placement_report.json",
    "quality_guardrails": "docs/quality_guardrails.md"
  },
  "outputs": [
    "outputs/solution_architecture_overview.png",
    "outputs/solution_architecture_overview.drawio",
    "outputs/solution_architecture_capability_*.png",
    "outputs/solution_architecture_capability_*.drawio",
    "outputs/prepared_input.json",
    "outputs/multilevel_plan.json",
    "outputs/<run_name>/layout_recommendations.json",
    "outputs/<run_name>/technology_placement_report.json"
  ],
  "compatible_interfaces": [
    "VS Code",
    "ChatGPT",
    "Google Gemini",
    "Claude",
    "Cursor",
    "agentic IDEs"
  ],
  "renderer": "Agents365 drawio-skill",
  "inputs": {
    "primary": "text",
    "optional": [
      "images"
    ],
    "behavior": "Accept text or JSON, optionally use images as supporting context, use internal reference architecture layouts, wrap text within boxes, avoid overlap, generate Level 2 capability diagrams when needed, and coordinate sub-agents with shared memory plus parallel-to-sequential fallback."
  },
  "files": [
    "run_architecture_skill.py",
    "docs/sub_agent_orchestration.md",
    "examples/request.txt",
    "render_with_drawio_adapter.py",
    "docs/renderer_adapter.md",
    "examples/renderer_config.json",
    "data/reference_asset_library.json",
    "docs/layout_semantics.md",
    "assets/reference_layouts/aws_unified_sustainability_hub.png",
    "assets/reference_layouts/aws_data_platform_large.png",
    "assets/reference_layouts/cloud_service_operating_model.png",
    "assets/reference_layouts/cloud_service_orchestration_portal.png",
    "assets/reference_layouts/iot_ot_risk_architecture.png",
    "assets/reference_layouts/modern_data_platform_databricks.png",
    "assets/reference_layouts/identity_centric_multicloud_landing_zone.png",
    "recommend_layouts.py",
    "validate_technology_placement.py",
    "docs/quality_guardrails.md",
    "data/technology_terms_allowlist.txt"
  ],
  "approvals_needed": [
    "Approve or install Agents365 drawio-skill in the target environment",
    "Approve or install draw.io desktop / CLI used by the renderer",
    "Approve the local renderer command template or bridge command",
    "Approve local subprocess execution from the orchestration runner",
    "Approve parallel render jobs if fan-out rendering is desired"
  ]
}