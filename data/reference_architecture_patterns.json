{
  "version": "1.3.0",
  "purpose": "Reference slide patterns and style families for generating solution architecture diagrams as PNG and draw.io files from user input.",
  "canvas_defaults": {
    "width": 1600,
    "height": 900,
    "background": "#FFFFFF",
    "font_family": "DejaVu Sans",
    "title_color": "#1F3B73",
    "body_color": "#222222",
    "line_color": "#6B7280"
  },
  "input_contract": {
    "title": "string",
    "subtitle": "string optional",
    "template": "one of: platform_value_chain, composite_ai_platform, cloud_tenant_microservices, enterprise_endpoint_management, cloud_data_platform, cloud_service_operating_model, service_orchestration_workflow, iot_ot_security_layers, modern_data_lakehouse, identity_multicloud_control_plane",
    "lanes": "array of source/target side lanes with label, items, side",
    "zones": "array of main architecture zones with title, subtitle, items, columns, color",
    "flows": "array of arrows between item ids or zone ids with label and direction",
    "footer": "string optional",
    "style": "optional palette, header band, and layout overrides"
  },
  "style_profiles": {
    "clean_enterprise_blue": {
      "primary": "#2F73D8",
