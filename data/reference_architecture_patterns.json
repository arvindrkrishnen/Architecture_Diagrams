  "generation_guidelines": {
    "diagram_density": "Prefer 18-50 labeled boxes. Keep labels short. Use multi-line wrapping.",
    "icon_policy": "Use simple geometric icons or labeled chips unless a licensed icon library is provided by the user.",
    "style_policy": "The output should be original and reference the layout patterns, not copy exact proprietary artwork.",
    "color_policy": "Borrow palette mood and segmentation logic, not exact brand art.",
    "placement_policy": "Use reference metadata to infer hierarchy: outer context rails, dominant boundaries, bands, lanes, and progression arrows.",
    "output": "PNG at 1600x900 by default."
  },
