{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Architecture Diagram Input Schema",
  "type": "object",
  "required": [
    "title",
    "template",
    "zones"
  ],
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },
    "subtitle": {
      "type": "string",
      "maxLength": 220
    },
    "template": {
      "type": "string",
      "enum": [
        "platform_value_chain",
        "composite_ai_platform",
        "cloud_tenant_microservices",
        "enterprise_endpoint_management",
        "cloud_data_platform",
        "cloud_service_operating_model",
        "service_orchestration_workflow",
        "iot_ot_security_layers",
        "modern_data_lakehouse",
        "identity_multicloud_control_plane"
      ]
    },
    "lanes": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "required": [
          "side",
          "title",
          "items"
        ],
        "additionalProperties": false,
        "properties": {
          "side": {
            "type": "string",
            "enum": [
              "left",
              "right",
              "top",
              "bottom"
            ]
          },
          "title": {
            "type": "string",
            "maxLength": 60
          },
          "items": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "string",
              "maxLength": 50
            }
          }
        }
      }
    },
    "zones": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "items"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_-]{2,40}$"
          },
          "title": {
            "type": "string",
            "maxLength": 80
          },
          "subtitle": {
            "type": "string",
            "maxLength": 120
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "string",
              "maxLength": 60
            }
          },
          "columns": {
            "type": "integer",
            "minimum": 1,
            "maximum": 4
          },
          "color": {
            "type": "string",
            "pattern": "^#?[A-Fa-f0-9]{6}$"
          },
          "expand": {
            "type": "boolean"
          },
          "children": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "flows": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false,
        "properties": {
          "from": {
            "type": "string",
            "maxLength": 40
          },
          "to": {
            "type": "string",
            "maxLength": 40
          },
          "label": {
            "type": "string",
            "maxLength": 60
          },
          "pattern": {
            "type": "string",
            "enum": [
              "sync_api",
              "async_event",
              "batch_etl",
              "streaming",
              "webhook",
              "pub_sub",
              "grpc",
              "file_transfer",
              "database_replication",
              "logical"
            ]
          },
          "direction": {
            "type": "string",
            "enum": [
              "source_to_target",
              "target_to_source",
              "bidirectional"
            ]
          },
          "payload_type": {
            "type": "string",
            "maxLength": 100
          },
          "protocol_style": {
            "type": "string",
            "maxLength": 100
          },
          "timing": {
            "type": "string",
            "enum": [
              "design_time",
              "build_time",
              "deploy_time",
              "runtime",
              "governance_time",
              "scheduled",
              "event_driven",
              "on_demand"
            ]
          }
        }
      }
    },
    "operations": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "string",
        "maxLength": 60
      }
    },
    "footer": {
      "type": "string",
      "maxLength": 180
    },
    "rendering_preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string"
        },
        "format": {
          "type": "string",
          "enum": [
            "png",
            "svg",
            "pdf",
            "jpg"
          ]
        },
        "embed_xml": {
          "type": "boolean"
        }
      }
    },
    "decomposition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auto_expand": {
          "type": "boolean"
        },
        "max_overview_zones": {
          "type": "integer",
          "minimum": 3,
          "maximum": 12
        },
        "max_items_per_zone_overview": {
          "type": "integer",
          "minimum": 3,
          "maximum": 12
        },
        "create_capability_children": {
          "type": "boolean"
        }
      }
    },
    "architecture_model": {
      "type": "object",
      "additionalProperties": true
    },
    "business_outcome_description": {
      "type": "string",
      "maxLength": 500
    },
    "domain": {
      "type": "string",
      "description": "Optional domain vocabulary pack, e.g. financial_services, healthcare, cloud_platform, ai_ml_platform."
    },
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "highlight",
              "risk_flag",
              "callout",
              "decision_point",
              "investment_marker"
            ]
          },
          "target_zone_id": {
            "type": "string"
          },
          "label": {
            "type": "string",
            "maxLength": 120
          },
          "color_role": {
            "type": "string"
          }
        }
      }
    },
    "source_content": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional article/blog extraction model."
    }
  }
}