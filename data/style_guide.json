  "visual_rules": {
    "container_style": "rounded containers with subtle fills and stronger header bars for major sections",
    "boundary_style": "dashed borders for trust zones, VPCs, clusters, environments, and organizational boundaries",
    "icon_label_style": "official icon above or left of short label; no more than 2 lines when possible",
    "legend_required_when": [
      "more than 4 domains",
      "multiple connector styles",
      "security overlays",
      "multi-cloud views"
    ],
    "font_rules": {
      "body_min_pt": 14,
      "header_min_pt": 16,
      "title_min_pt": 26,
      "internal_padding_px": 12
    },
    "connector_rules": "orthogonal connectors only; no diagonal lines; route around boxes and avoid crossing major containers",
    "level1_style": "executive polish with strong visual hierarchy, clear focal point, generous but not wasteful whitespace",
    "annotation_rules": {
      "highlight": "small pill callout on target zone header",
      "risk_flag": "red warning flag anchored to target zone",
      "callout": "small side note linked with a thin orthogonal connector"
    }
  },
